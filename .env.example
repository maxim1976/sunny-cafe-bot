# ── LINE Messaging API ─────────────────────────────────────────────────────
# Get these from https://developers.line.biz/console/
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# ── Anthropic Claude API ───────────────────────────────────────────────────
# Get your key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Kitchen Printer (Epson TM-T20 or compatible ESC/POS via TCP) ───────────
PRINTER_IP=192.168.1.100
PRINTER_PORT=9100

# ── Database ───────────────────────────────────────────────────────────────
# SQLite (local/Railway volume). Use the path directly:
DATABASE_URL=sqlite:///chat.db

# ── Flask ──────────────────────────────────────────────────────────────────
# Railway injects PORT automatically; set manually for local dev if needed.
PORT=5000
